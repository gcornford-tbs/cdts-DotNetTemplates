@{
    #pragma warning disable 8600, 8602
    GoC.WebTemplate.Components.IModel WebTemplateModel = (GoC.WebTemplate.Components.IModel)ViewData["WebTemplateModel"];
    var wetJsAttrs = WebTemplateModel.Builder.BuildWetJsPathAttributes(WebTemplateModel.TwoLetterCultureLanguage);
    var cdtsSetup = WebTemplateModel.Render.SplashSetup();
}
<!DOCTYPE html>

<!--[if lt IE 9]><html class="no-js lt-ie9" lang="@WebTemplateModel.TwoLetterCultureLanguage" dir="ltr"><![endif]-->
<!--[if gt IE 8]><!-->
<html xmlns="http://www.w3.org/1999/xhtml" class="no-js" lang="@WebTemplateModel.TwoLetterCultureLanguage" dir="ltr">
<!--<![endif]-->
<head>
    <meta charset="utf-8" />
    <!-- Web Experience Toolkit (WET) / Boîte à outils de l'expérience Web (BOEW)
        wet-boew.github.io/wet-boew/License-en.html / wet-boew.github.io/wet-boew/Licence-fr.html -->
    <title>@WebTemplateModel.Render.HeaderTitle()</title>
    <meta content="width=device-width,initial-scale=1" name="viewport" />
    <!-- Load closure template scripts -->
    @Html.Raw("<link rel=\"stylesheet\" " + WebTemplateModel.SplashCSSPath + ">")
    @Html.Raw("<script type=\"text/javascript\" " + wetJsAttrs + " data-cdts-setup='" + cdtsSetup + "'></script>")
    <noscript>
        <!-- Write closure fall-back static file -->
        @WebTemplateModel.LoadStaticFile("refTop.html")
    </noscript>
    <!-- Write closure template -->
    @WebTemplateModel.Render.HtmlHeaderElements()
    @RenderSection("CustomStyles", required: false)
</head>
<body class="splash" vocab="http://schema.org/" typeof="WebPage">
    <div id="cdts-splash-content">
        <!-- Write closure fall-back static file -->
        @WebTemplateModel.LoadStaticFile("splash.html")
    </div>
    @RenderBody()
</body>
</html>
